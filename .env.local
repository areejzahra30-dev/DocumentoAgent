# =============================================================================
# Documento Agent — Local Development Environment
# =============================================================================
# Copy this file content into frontend/.env.local AND backend/.env
# Fill in the values below before running the app.
# =============================================================================

# ─── Shared ───────────────────────────────────────────────────────────────────

# BetterAuth — Generate this with: openssl rand -base64 32 (min 32 chars)
# MUST be identical in both frontend/.env.local and backend/.env
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars-long

# ─── Frontend (→ frontend/.env.local) ────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Neon PostgreSQL connection string (standard, for BetterAuth)
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/docagent?sslmode=require

# UploadThing
NEXT_PUBLIC_UPLOADTHING_APP_ID=your_uploadthing_app_id
UPLOADTHING_SECRET=your_uploadthing_secret

# ─── Backend (→ backend/.env) ────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Neon PostgreSQL connection string (async, for SQLAlchemy)
# Use the same host/database as the DATABASE_URL above, but with asyncpg driver
DATABASE_URL=postgresql+asyncpg://user:password@ep-example-123456.us-east-2.aws.neon.tech/docagent?sslmode=require

# Auth (must match the BETTER_AUTH_SECRET set above)
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3000

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# UploadThing (for backend file downloads — same as frontend secret)
UPLOADTHING_SECRET=your_uploadthing_secret

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=DEBUG

# =============================================================================
# How to generate secure secrets:
#   - Windows (PowerShell):   [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
#   - macOS/Linux:            openssl rand -base64 32
# =============================================================================
