# =============================================================================
# Documento Agent — Environment Variables Template
# =============================================================================
# Copy this file to:
#   - frontend/.env.local  (for Next.js frontend)
#   - backend/.env         (for Python FastAPI backend)
# =============================================================================

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────

# URL of the FastAPI backend (used by Next.js API routes and client)
NEXT_PUBLIC_API_URL=http://localhost:8000

# BetterAuth — base URL of the Next.js app itself
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# BetterAuth — secret key for JWT signing (min 32 characters, generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# BetterAuth — database URL (same Neon PostgreSQL instance, shared with backend)
# BetterAuth will create its own tables (user, session, account, verification)
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/docagent?sslmode=require

# UploadThing — file storage service
# Get these from https://uploadthing.com/dashboard
NEXT_PUBLIC_UPLOADTHING_APP_ID=
UPLOADTHING_SECRET=

# UploadThing — token (optional, depending on SDK version)
# UPLOADTHING_TOKEN=

# ─── KokonutUI AI Input ──────────────────────────────────────────────────────
# (No API key required — component uses the backend Gemini endpoint)

# ─── Backend (FastAPI / Python) ──────────────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Database — Neon PostgreSQL (async connection string)
# Use the same database as BetterAuth for simplicity
DATABASE_URL=postgresql+asyncpg://user:password@ep-example-123456.us-east-2.aws.neon.tech/docagent?sslmode=require

# Authentication — shared JWT secret (must match BETTER_AUTH_SECRET above exactly)
# Used by FastAPI to verify tokens issued by BetterAuth
BETTER_AUTH_SECRET=

# Authentication — BetterAuth URL (for fallback token verification via HTTP)
BETTER_AUTH_URL=http://localhost:3000

# AI — Google Gemini API
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# UploadThing — secret (for downloading files on the backend side)
# Must match the UPLOADTHING_SECRET from the UploadThing dashboard
UPLOADTHING_SECRET=

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=DEBUG

# ─── Deployment (Render) ─────────────────────────────────────────────────────

# These are set in Render dashboard, not in .env files
# RENDER=true
# RENDER_SERVICE_ID=
# RENDER_INSTANCE_ID=
