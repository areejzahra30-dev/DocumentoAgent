Enum "output_type" {
  "readme"
  "summary"
}

Enum "agent_status" {
  "uploading"
  "parsing"
  "analyzing"
  "planning"
  "generating"
  "reviewing"
  "completed"
  "failed"
}

Enum "parse_status" {
  "pending"
  "parsing"
  "parsed"
  "failed"
}

Table "users" {
  "id"             uuid         [pk, default: `gen_random_uuid()`]
  "username"       varchar(50)  [not null, unique]
  "email"          varchar(255) [not null, unique]
  "email_verified" boolean      [not null, default: false]
  "password_hash"  varchar(255) [not null]
  "image"          text         [null]
  "created_at"     timestamptz  [not null, default: `now()`]
  "updated_at"     timestamptz  [not null, default: `now()`]
}

Table "sessions" {
  "id"          uuid         [pk, default: `gen_random_uuid()`]
  "user_id"     uuid         [not null]
  "token"       varchar(512) [not null, unique]
  "expires_at"  timestamptz  [not null]
  "ip_address"  varchar(45)  [null]
  "user_agent"  text         [null]
  "created_at"  timestamptz  [not null, default: `now()`]
  "updated_at"  timestamptz  [not null, default: `now()`]

  indexes {
    user_id [name: "idx_sessions_user_id"]
  }
}

Table "accounts" {
  "id"                      uuid         [pk, default: `gen_random_uuid()`]
  "user_id"                 uuid         [not null]
  "account_id"              varchar(255) [not null, note: "provider's user identifier, e.g. email for credentials"]
  "provider_id"             varchar(50)  [not null, note: "e.g. credentials"]
  "access_token"            text         [null]
  "refresh_token"           text         [null]
  "access_token_expires_at" timestamptz  [null]
  "created_at"              timestamptz  [not null, default: `now()`]
  "updated_at"              timestamptz  [not null, default: `now()`]

  indexes {
    (user_id, provider_id) [unique, name: "uq_accounts_user_provider"]
  }
}

Table "projects" {
  "id"          uuid         [pk, default: `gen_random_uuid()`]
  "user_id"     uuid         [not null]
  "name"        varchar(255) [not null]
  "is_deleted"  boolean      [not null, default: false]
  "deleted_at"  timestamptz  [null]
  "created_at"  timestamptz  [not null, default: `now()`]
  "updated_at"  timestamptz  [not null, default: `now()`]

  indexes {
    user_id [name: "idx_projects_user_id"]
    (user_id, is_deleted) [name: "idx_projects_user_active"]
  }
}

Table "project_name_history" {
  "id"            uuid         [pk, default: `gen_random_uuid()`]
  "project_id"    uuid         [not null]
  "previous_name" varchar(255) [not null]
  "new_name"      varchar(255) [not null]
  "changed_at"    timestamptz  [not null, default: `now()`]

  indexes {
    project_id [name: "idx_project_name_history_project_id"]
  }
}

Table "uploads" {
  "id"               uuid          [pk, default: `gen_random_uuid()`]
  "project_id"       uuid          [not null]
  "original_name"    varchar(500)  [not null]
  "storage_key"      varchar(500)  [not null, unique, note: "UploadThing file key"]
  "storage_url"      text          [not null]
  "mime_type"        varchar(100)  [not null]
  "file_type"        varchar(50)   [not null, note: "pdf, docx, pptx, xlsx, txt, md, image, etc."]
  "file_size_bytes"  bigint        [not null]
  "parse_status"     parse_status  [not null, default: 'pending']
  "created_at"       timestamptz   [not null, default: `now()`]
  "updated_at"       timestamptz   [not null, default: `now()`]

  indexes {
    project_id [name: "idx_uploads_project_id"]
    storage_key [name: "idx_uploads_storage_key"]
  }
}

Table "outputs" {
  "id"                    uuid          [pk, default: `gen_random_uuid()`]
  "project_id"            uuid          [not null]
  "output_type"           output_type   [not null]
  "version"               integer       [not null, default: 1, note: "monotonically increasing per project+type"]
  "content"               text          [not null]
  "agent_status"          agent_status  [not null, default: 'uploading']
  "model_used"            varchar(100)  [null, note: "e.g. gemini-2.5-flash"]
  "generation_metadata"   jsonb         [null, note: "tokens used, latency, etc."]
  "created_at"            timestamptz   [not null, default: `now()`]
  "updated_at"            timestamptz   [not null, default: `now()`]

  indexes {
    (project_id, output_type, version) [unique, name: "uq_outputs_project_type_version"]
    project_id [name: "idx_outputs_project_id"]
    (project_id, output_type) [name: "idx_outputs_project_type"]
  }
}

Ref: "sessions"."user_id"              > "users"."id"    [delete: cascade]
Ref: "accounts"."user_id"              > "users"."id"    [delete: cascade]
Ref: "projects"."user_id"              > "users"."id"    [delete: cascade]
Ref: "project_name_history"."project_id" > "projects"."id" [delete: cascade]
Ref: "uploads"."project_id"            > "projects"."id" [delete: cascade]
Ref: "outputs"."project_id"            > "projects"."id" [delete: cascade]